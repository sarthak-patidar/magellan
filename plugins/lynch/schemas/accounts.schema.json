{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["accounts"],
  "properties": {
    "accounts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "broker", "market", "currency", "source", "residency"],
        "properties": {
          "id": {"type": "string"},
          "broker": {"enum": ["zerodha_kite", "zerodha_coin", "indmoney_alpaca"]},
          "market": {"enum": ["IN", "US"]},
          "currency": {"enum": ["INR", "USD"]},
          "source": {"enum": ["csv", "mcp"]},
          "residency": {"enum": ["IN", "US"]}
        }
      }
    }
  }
}
